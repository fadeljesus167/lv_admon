<!DOCTYPE html>
<html>
  <head>
    <title>LvAdmon</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="p-3 border-bottom bg-white bg-body-tertiary">
      <div class="container-fluid d-flex justify-content-between align-items-center">
        <%= link_to root_path , class: 'navbar-brand' do %>
          <%= image_tag "https://logosmarcas.net/wp-content/uploads/2020/09/Linux-Simbolo.png", width: 75, alt: "Logo App" %>
          LvAdmon
        <% end %>

        <%= link_to t('.logout_link'), logout_path, class: 'btn btn-outline-danger btn-sm', data: { turbo_method: :delete, turbo_confirm: t('confirm') } if logged_in? %>
      </div>
    </header>

    <div class="mx-4">
      <div class="container my-5">
        <div class="row g-4 justify-content-center">
          
          <div class="col-12 col-md-6 col-lg-3">
            <%= link_to students_path, class: "text-decoration-none" do %>
              <div class="card h-100 text-center border-primary shadow-sm hover-shadow">
                <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                  <i class="bi bi-people fs-1 mb-3 text-primary"></i> <h5 class="card-title text-dark">Estudiantes</h5>
                </div>
              </div>
            <% end %>
          </div>

          <div class="col-12 col-md-6 col-lg-3">
            <%= link_to payments_path, class: "text-decoration-none" do %>
              <div class="card h-100 text-center border-success shadow-sm">
                <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                  <i class="bi bi-currency-dollar fs-1 mb-3 text-success"></i>
                  <h5 class="card-title text-dark">Pagos</h5>
                </div>
              </div>
            <% end %>
          </div>

          <div class="col-12 col-md-6 col-lg-3">
            <%= link_to payments_verify_path, class: "text-decoration-none" do %>
              <div class="card h-100 text-center border-warning shadow-sm">
                <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                  <i class="bi bi-shield-check fs-1 mb-3 text-warning"></i>
                  <h5 class="card-title text-dark">Verificación de pagos</h5>
                </div>
              </div>
            <% end %>
          </div>

          <div class="col-12 col-md-6 col-lg-3">
            <%= link_to bills_path, class: "text-decoration-none" do %>
              <div class="card h-100 text-center border-info shadow-sm">
                <div class="card-body d-flex flex-column align-items-center justify-content-center py-5">
                  <i class="bi bi-file-earmark-text fs-1 mb-3 text-info"></i>
                  <h5 class="card-title text-dark">Facturas</h5>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
